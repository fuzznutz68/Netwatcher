<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- App Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a237e"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔭 NetWatch"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Domain Monitor"
            android:textColor="#90caf9"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#283593"
        app:tabTextColor="#90caf9"
        app:tabSelectedTextColor="#ffffff"
        app:tabIndicatorColor="#64b5f6"
        app:tabIndicatorHeight="3dp" />

    <!-- Tab 1: Domain Intel -->
    <LinearLayout
        android:id="@+id/tab1Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ffffff"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <EditText
                android:id="@+id/domainInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Enter domain (e.g. google.com)"
                android:inputType="textUri"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

            <Button
                android:id="@+id/lookupBtn"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="Scan"
                android:backgroundTint="#1a237e"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="#1565c0"
            android:visibility="gone"
            android:textSize="14sp" />

        <!-- Results -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/resultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />
        </ScrollView>
    </LinearLayout>

    <!-- Tab 2: Traffic Monitor -->
    <LinearLayout
        android:id="@+id/tab2Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ffffff"
            android:padding="12dp"
            android:orientation="vertical"
            android:elevation="4dp">

            <EditText
                android:id="@+id/targetDomainInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Domain to monitor (e.g. facebook.com)"
                android:inputType="textUri"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/startVpnBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="▶ Start Monitoring"
                    android:backgroundTint="#1b5e20"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/stopVpnBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="⏹ Stop"
                    android:backgroundTint="#b71c1c"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- VPN Status -->
            <TextView
                android:id="@+id/vpnStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="🔴 Not monitoring"
                android:textSize="14sp"
                android:textColor="#757575"
                android:gravity="center" />
        </LinearLayout>

        <!-- Column Headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#e3f2fd"
            android:padding="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  DIR      PROTOCOL     HOST / IP : PORT                SIZE       TIME"
                android:textSize="11sp"
                android:textColor="#1565c0"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Live Traffic Log -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/trafficLogContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
