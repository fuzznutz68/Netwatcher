        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="TabButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">#8892A4</item>
        <item name="android:background">@drawable/tab_selector</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="ValueText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#C8D8E8</item>
        <item name="android:fontFamily">monospace</item>
