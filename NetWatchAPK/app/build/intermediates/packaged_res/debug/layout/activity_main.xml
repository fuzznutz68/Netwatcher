<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060F1E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A1628"
        android:padding="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡 NetWatch"
            android:textSize="22sp"
            android:textColor="#E3F2FD"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Domain Intelligence &amp; Traffic Monitor"
            android:textSize="12sp"
            android:textColor="#90A4AE"/>
    </LinearLayout>

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#0A1628">

        <Button
            android:id="@+id/tabDomainBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="🔍 Domain Intel"
            android:textColor="#FFFFFF"
            android:background="@drawable/tab_selector"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/tabTrafficBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="📡 Traffic Monitor"
            android:textColor="#FFFFFF"
            android:background="@drawable/tab_selector"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Tab 1: Domain Intel -->
    <ScrollView
        android:id="@+id/tab1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Input Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/domainInput"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:hint="Enter domain (e.g. google.com)"
                    android:textColor="#E3F2FD"
                    android:textColorHint="#546E7A"
                    android:background="@drawable/input_background"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/lookupBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginLeft="8dp"
                    android:text="SCAN"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"/>
            </LinearLayout>

            <!-- Status -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter a domain and tap SCAN"
                android:textColor="#78909C"
                android:textSize="13sp"
                android:layout_marginBottom="10dp"/>

            <!-- Results container -->
            <LinearLayout
                android:id="@+id/resultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>

    <!-- Tab 2: Traffic Monitor -->
    <LinearLayout
        android:id="@+id/tab2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <!-- Controls Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TARGET DOMAIN"
                android:textSize="11sp"
                android:textColor="#64B5F6"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/targetDomainInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g. google.com or *.google.com"
                android:textColor="#E3F2FD"
                android:textColorHint="#546E7A"
                android:background="@drawable/input_background"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:inputType="text"
                android:singleLine="true"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/startVpnBtn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="▶  START MONITORING"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:textSize="13sp"/>

                <Button
                    android:id="@+id/stopVpnBtn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginLeft="8dp"
                    android:text="■  STOP"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_danger"
                    android:textSize="13sp"
                    android:enabled="false"/>
            </LinearLayout>
        </LinearLayout>

        <!-- VPN Status -->
        <TextView
            android:id="@+id/vpnStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● Monitoring inactive"
            android:textColor="#78909C"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <!-- Traffic Log -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE TRAFFIC LOG"
            android:textSize="11sp"
            android:textColor="#64B5F6"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp"/>

        <ScrollView
            android:id="@+id/trafficScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_background">

            <LinearLayout
                android:id="@+id/trafficLogContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"/>
        </ScrollView>

    </LinearLayout>

</LinearLayout>
